{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "paths": {
      "@plannotator/shared/*": ["../shared/*"],
      "@plannotator/ui/*": ["../ui/*"]
    }
  },
  "include": ["."]
}
